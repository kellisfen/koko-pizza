# Копируйте этот файл в .env и заполните реальными значениями

# Секретный ключ для JWT (ОБЯЗАТЕЛЬНО измените!)
SECRET_KEY=your-super-secret-key-change-this-in-production

# База данных PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/koko_pizza

# Режим отладки (только для разработки)
DEBUG=true

# Название приложения
APP_NAME=Koko Pizza API
